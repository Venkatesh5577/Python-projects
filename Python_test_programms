#Guess_game
secret_num = 12

guess_counts = 0
guess_attempts = 3

while guess_attempts > guess_counts:
    guess_num = int(input("Guess a number : "))
    guess_counts += 1

    if guess_num == secret_num:
        print("Congratulations! You guessed it!")
        break   # stop the loop immediately

else:
    print("Sorry, you didn't guess it!")

#car_game
while True:
    car = input('> ').lower()

    if car == 'start':
        print('Welcome to Nascar kid! (this is Mic your driving assistant), car is started')
    elif car == 'stop':
        print("Car stopped, kid what happened!!")
    elif car == 'restart':
        print("Going to pit stop, hurry!")
    elif car == 'home':
        print("Menu: resume | exit race | help")
    elif car == 'pass':
        print("That's how you overtake the opponents kid! (Mic)")
    elif car == 'help':
        print("Ambulance on the way!")
    elif car == 'exit':
        print("Exiting race...")
        break
    else:
        print("Do not understand, please choose valid race command")

