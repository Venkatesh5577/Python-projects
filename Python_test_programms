# Guessing_number-game
import random
n = random.randint(1,10)
tries = 0
while True:
    guess = int(input("Guess a number: "))
    if guess == n:
       tries += 1
       print(f'You guessed it! in {tries} tries')
       break

    elif guess < n:
        print("Too low")
        tries += 1
    elif guess > n:
        print("Too high")
        tries += 1
    else:
        print("wrong")
        tries += 1

#defining_function
def palin(a):
    rev = ""
    for i in range(len(a) - 1,-1,-1 ):
        rev = rev + a[i]

    if rev == a:
       print(f"{a} is a Palindrome")
    else:
        print(f"{a} is not a Palindrome")

